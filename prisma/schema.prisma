generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Node {
  id         String    @id @default(uuid())
  name       String
  type       String
  mimeType   String?
  size       Int?
  path       String?
  isTrashed  Boolean   @default(false)
  isStarred  Boolean   @default(false)
  creator    String?
  verifier1  String?
  verifier2  String?
  verifier3  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  parentId   String?
  areaFolder Area?     @relation("AreaFolderNode")
  document   Document? @relation("DocumentNode")
  parent     Node?     @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   Node[]    @relation("FolderHierarchy")

  @@index([parentId])
}

model User {
  id         String      @id @default(uuid())
  username   String      @unique
  password   String
  name       String
  role       String
  signature  String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  areaId     String?
  cargo      String?
  email      String?
  documents  Document[]  @relation("CreatorRelation")
  sessions   Session[]
  signatures Signature[]
  area       Area?       @relation("UserArea", fields: [areaId], references: [id])
  verifiers  Verifier[]

  @@index([areaId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Session_userId_fkey")
}

model Area {
  id           String     @id @default(uuid())
  name         String     @unique
  color        String?
  folderNodeId String?    @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  folderNode   Node?      @relation("AreaFolderNode", fields: [folderNodeId], references: [id])
  documents    Document[]
  users        User[]     @relation("UserArea")
  verifiers    Verifier[]

  @@index([folderNodeId])
}

model Verifier {
  id        String   @id @default(uuid())
  areaId    String
  userId    String
  signOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([areaId, userId])
  @@index([areaId])
  @@index([userId])
}

model Document {
  id         String      @id @default(uuid())
  areaId     String
  nodeId     String?     @unique
  status     String
  creatorId  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  area       Area        @relation(fields: [areaId], references: [id], onDelete: Cascade)
  creator    User        @relation("CreatorRelation", fields: [creatorId], references: [id], onDelete: Cascade)
  node       Node?       @relation("DocumentNode", fields: [nodeId], references: [id], onDelete: Cascade)
  signatures Signature[]

  @@index([areaId])
  @@index([creatorId])
  @@index([nodeId])
}

model Signature {
  id         String    @id @default(uuid())
  documentId String
  userId     String
  status     String
  signedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  coordX     Float?
  coordY     Float?
  ipAddress  String?
  pageNumber Int?
  document   Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
}

model Audit {
  id        String   @id @default(uuid())
  username  String
  action    String
  detail    String   @db.Text
  createdAt DateTime @default(now())
}

model MaintUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id         String   @id @default(uuid())
  title      String
  periodFrom String
  periodTo   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  items      Item[]
}

model Item {
  id          String    @id @default(uuid())
  reportId    String
  itemNumber  Int
  date        String
  responsable String
  report      Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  machines    Machine[]

  @@index([reportId])
}

model Machine {
  id     String @id @default(uuid())
  itemId String
  name   String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([itemId])
}

model Task {
  id          String  @id @default(uuid())
  machineId   String
  falla       String
  tipo        String
  descripcion String
  repuestos   String
  cantidad    String
  estado      String
  machine     Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
}

model Tarea {
  id                   String         @id @default(uuid())
  responsable          String
  descripcion          String         @db.Text
  estado               String         @default("PENDIENTE")
  fecha_creacion       DateTime       @default(now())
  fecha_actualizacion  DateTime       @updatedAt
  cantidad             String?
  equipo               String?
  falla                String?        @db.Text
  fecha                String?
  itemNumber           Int?
  repuestos            String?
  sede                 String?
  tipo                 String?
  esRecurrente         Boolean        @default(true)
  fechaUltimaEjecucion String?
  frecuenciaMeses      Int?
  proximaEjecucion     String?
  tareaPadreId         String?
  certificadoNombre    String?
  certificadoPath      String?
  fechaCulminado       String?
  TareaArchivo         TareaArchivo[]

  @@map("Tarea")
}

model Responsable {
  id        String   @id @default(uuid())
  nombre    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Responsable")
}

model SparePart {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique
  stock           Int      @default(0)
  minStock        Int      @default(0)
  price           Float?
  location        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isMatachana     Boolean  @default(false)
  almacenado      String?  @default("")
  codigoMarca     String?  @default("")
  codigoMatachana String?  @default("")
  comentario      String?  @default("")
  correlativo     String?  @default("")
  descripcion     String?  @default("")
  fotoNombre      String?  @default("")
  fotoPath        String?  @default("")
  kit1            String?  @default("")
  kit2            String?  @default("")
  marca1          String?  @default("")
  metodo          String?  @default("")
  metodo2         String?  @default("")
  repuesto        String?  @default("")
  seccion         String?  @default("")
  usados          Int      @default(0)
}

model License {
  id                          String           @id @default(uuid())
  name                        String
  entity                      String
  code                        String?
  issueDate                   String
  expiryDate                  String
  status                      String
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  archivoNombre               String?
  archivoPath                 String?
  carpetaId                   String?
  archivoNombreCertificado    String?
  archivoNombreCheckList      String?
  archivoNombreFactura        String?
  archivoNombreInformeTecnico String?
  archivoNombrePresupuesto    String?
  archivoNombreProtocolo      String?
  archivoPathCertificado      String?
  archivoPathCheckList        String?
  archivoPathFactura          String?
  archivoPathInformeTecnico   String?
  archivoPathPresupuesto      String?
  archivoPathProtocolo        String?
  details                     String?
  vencimientoCertificado      String?
  vencimientoCheckList        String?
  vencimientoFactura          String?
  vencimientoInformeTecnico   String?
  vencimientoPresupuesto      String?
  vencimientoProtocolo        String?
  carpeta                     LicenciaCarpeta? @relation("FolderLicenses", fields: [carpetaId], references: [id])

  @@index([carpetaId])
}

model LicenciaCarpeta {
  id        String    @id @default(uuid())
  nombre    String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  licenses  License[] @relation("FolderLicenses")
}

model TareaArchivo {
  id           String   @id
  tareaId      String
  originalName String
  path         String
  createdAt    DateTime @default(now())
  Tarea        Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  @@index([tareaId])
}
